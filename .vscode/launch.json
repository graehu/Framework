{
    "configurations": [
            {
            "name": "(gdb) Launch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}.bin",
            "args": ["-log.default.level", "debug"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "(lldb) Launch",
            "type": "lldb-dap",
            "request": "launch",
            "cwd": "${fileDirname}",
            "stopOnEntry": false,
            "program": "${fileDirname}/${fileBasenameNoExtension}.bin",
            "args": ["-log.default.level", "debug"],
            "env": [
                    "LSAN_OPTIONS=verbosity=1:log_threads=1"
            ]
        }
    ],
    "version": "2.0.0"
}